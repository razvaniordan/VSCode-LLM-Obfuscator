{
  "name": "llm-c-obfuscator",
  "displayName": "llm-c-obfuscator",
  "description": "VS Code extension for LLM-based C code obfuscation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:llm-c-obfuscator.obfuscateSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "llm-c-obfuscator.obfuscateSelection",
        "title": "LLM C Obfuscator: Obfuscate Selected C Code"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "copy-prompts": "node ./scripts/copyPrompts.js",
    "build": "npm run compile && npm run copy-prompts",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.34.0"
  },
  "configuration": {
    "title": "LLM C Obfuscator",
    "properties": {
      "llm-c-obfuscator.model": {
        "type": "string",
        "default": "gpt-5.4-mini",
        "description": "Model name to send to the selected provider."
      }
    }
  }
}
